{
  "name": "@adkerala/electron",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "dev":    "tsc && electron dist/main.js",
    "build":  "tsc",
    "pack":   "electron-builder --dir",
    "dist":   "electron-builder"
  },
  "dependencies": {
    "@adkerala/types": "*",
    "bonjour-service": "^1.2.1",
    "ws": "^8.17.0",
    "better-sqlite3": "^9.6.0",
    "electron-store": "^8.2.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.10",
    "@types/ws": "^8.5.10",
    "@types/node": "^20.14.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "typescript": "*"
  },
  "build": {
    "appId": "in.adkerala.display",
    "productName": "adkerala Display",
    "linux": { "target": "AppImage" },
    "win":   { "target": "nsis" }
  }
}

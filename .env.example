# ─── Database ───────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/adkerala"

# ─── Redis ──────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Auth ───────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="change-me-32-chars-minimum"
NEXTAUTH_URL="http://localhost:3000"

# ─── Cloudflare R2 (audio files + ad media) ─────────────────────────────
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key"
R2_SECRET_ACCESS_KEY="your-r2-secret-key"
R2_BUCKET="adkerala-media"
R2_PUBLIC_URL="https://media.adkerala.in"

# ─── Google Cloud TTS (Malayalam audio generation) ──────────────────────
GOOGLE_APPLICATION_CREDENTIALS="./gcloud-key.json"
# or inline:
# GCLOUD_TTS_KEY="base64-encoded-service-account-json"

# ─── Mapbox (admin fleet map) ────────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN="pk.eyJ1IjoiYWRrZXJhbGEiLCJhIjoiY..."

# ─── App ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
PORT=3000
NODE_ENV="development"

# ─── ESP32 signing (optional — HMAC token validation) ───────────────────
ESP32_SHARED_SECRET="change-me-esp32-secret"
